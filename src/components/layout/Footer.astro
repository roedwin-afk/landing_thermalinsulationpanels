---
import NavLinks from "../ui/NavLinks.astro";
import type { TranslationKeys } from "../../i18n/en";
import type { Lang } from "../../i18n/utils";
import { Image } from "astro:assets";

import logo from "../../assets/logo.svg";

interface Props {
  t: TranslationKeys;
  lang: Lang;
}

const { t, lang } = Astro.props;

const base = lang === "es" ? "/es" : "";


---

<footer class="footer" role="contentinfo">
  <div class="container">

    <!-- Top grid -->
    <div class="footer__grid">

      <!-- Brand -->
      <div class="footer__brand">
        <a href={`${base}/`} class="footer__logo" aria-label="Thermal Insulation Panels">
          <div class="footer__logo-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
              fill="none" stroke="currentColor" stroke-width="2.5"
              stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <Image
          src={logo}
          alt="Panel sándwich para techo industrial"
          width={200}
          height={50}
          class="footer__logo-img"
          format="svg"
          quality={85}
          loading="eager"
        />
        </a>
        <p class="footer__tagline">{t.footer.tagline}</p>
      </div>

      <!-- Navigation -->
      <div class="footer__col">
        <h4 class="footer__heading">{t.footer.nav}</h4>
        <NavLinks t={t} lang={lang} variant="footer" />
      </div>

      <!-- Legal -->
      <div class="footer__col">
        <h4 class="footer__heading">{t.footer.legal}</h4>
        <p class="footer__disclaimer">{t.footer.disclaimer}</p>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="footer__bottom">
      <span class="footer__copyright">{t.footer.copyright}</span>
      <div class="footer__legal-links">
        <a href={`${base}/privacy`} class="footer__legal-link">{t.footer.privacy}</a>
        <a href={`${base}/terms`}   class="footer__legal-link">{t.footer.terms}</a>
      </div>
    </div>

  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-slate-900);
    color: var(--color-slate-400);
    padding-top: var(--space-16);
    padding-bottom: var(--space-8);
    border-top: 1px solid var(--color-slate-800);
  }

  /* ─── Grid ─── */
  .footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    padding-bottom: var(--space-12);
    border-bottom: 1px solid var(--color-slate-800);
  }

  @media (min-width: 640px) {
    .footer__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .footer__grid {
      grid-template-columns: 3fr 1fr 1.5fr;
    }
  }

  /* ─── Brand ─── */
  .footer__brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .footer__logo {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
  }
  .footer__logo-img {
        display: block;
        height: 4.5rem;
        width: auto;
        filter: brightness(0) invert(1);
    }


  .footer__logo-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    background-color: var(--color-brand-600);
    border-radius: var(--radius-md);
    color: white;
    flex-shrink: 0;
  }

  .footer__logo-name {
    font-size: var(--text-base);
    font-weight: 700;
    color: white;
  }

  .footer__tagline {
    font-size: var(--text-xs);
    line-height: 1.6;
    max-width: 58ch; */
  }

  /* ─── Columns ─── */
  .footer__col {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .footer__heading {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: white;
  }

  /* ─── Domains ─── */
  .footer__domains {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .footer__domain {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    color: var(--color-slate-400);
    transition: color var(--transition-fast);
  }

  .footer__domain--active {
    color: var(--color-brand-600);
  }

  /* ─── Disclaimer ─── */
  .footer__disclaimer {
    font-size: 0.6875rem;
    line-height: 1.6;
  }

  /* ─── Bottom bar ─── */
  .footer__bottom {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    padding-top: var(--space-8);
    text-align: center;
  }

  @media (min-width: 640px) {
    .footer__bottom {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }

  .footer__copyright {
    font-size: var(--text-xs);
  }

  .footer__legal-links {
    display: flex;
    gap: var(--space-6);
  }

  .footer__legal-link {
    font-size: var(--text-xs);
    color: var(--color-slate-400);
    transition: color var(--transition-fast);
  }

  .footer__legal-link:hover {
    color: white;
  }
</style>