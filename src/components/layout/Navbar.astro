---
import NavLinks from "../ui/NavLinks.astro";
import MobileMenu from "./MobileMenu.astro";
import type { TranslationKeys } from "../../i18n/en";
import type { Lang } from "../../i18n/utils";
import { Image } from "astro:assets";

import logo from "../../assets/logo.svg";

interface Props {
  t: TranslationKeys;
  lang: Lang;
  alternatePath: any;
}

const { t, lang, alternatePath } = Astro.props;



const base = import.meta.env.BASE_URL;
const homeURL = lang === "en" ? `${base}` : `${base}es/`;
const altHref = alternatePath;
const altLabel = lang === "es" ? "EN" : "ES";

---

<header class="navbar" role="banner">
  <div class="container">
    <div class="navbar__inner">

      <!-- Logo -->
      <a href={homeURL} class="navbar__logo" aria-label="Thermal Insulation Panels - Home">
        <div class="navbar__logo-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24"
            fill="none" stroke="currentColor" stroke-width="2.5"
            stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
        </div>
        <Image
          src={logo}
          alt="Panel sándwich para techo industrial"
          width={200}
          height={50}
          class="navbar__logo-img"
          format="svg"
          quality={85}
          loading="eager"
        />
      </a>

      <!-- Desktop nav -->
      <nav class="navbar__nav" aria-label="Main navigation">
        <NavLinks t={t} lang={lang} variant="navbar" />
      </nav>

      <!-- Right actions -->
      <div class="navbar__actions">
        <!-- Language switcher -->
        <a href={altHref} class="navbar__lang" aria-label={`Switch to ${altLabel}`}>
          {altLabel}
        </a>

        <!-- CTA -->
        <a href={`${base}contact`} class="navbar__cta">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
            fill="none" stroke="currentColor" stroke-width="2.5"
            stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="7 10 12 15 17 10"/>
            <line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          {t.contact.title}
        </a>

        <!-- Mobile toggle -->
        <button
          class="navbar__burger"
          id="burger-btn"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="Toggle navigation menu"
        >
          <svg id="icon-menu" xmlns="http://www.w3.org/2000/svg" width="24" height="24"
            viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="4" y1="6" x2="20" y2="6"/>
            <line x1="4" y1="12" x2="20" y2="12"/>
            <line x1="4" y1="18" x2="20" y2="18"/>
          </svg>
          <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" width="24" height="24"
            viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round"
            aria-hidden="true" style="display:none">
            <line x1="18" y1="6" x2="6" y2="18"/>
            <line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <MobileMenu t={t} lang={lang} alternatePath={alternatePath} />
</header>

<style>
  .navbar {
    position: sticky;
    top: 0;
    z-index: 50;
    background-color: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-slate-100);
    box-shadow: var(--shadow-sm);
  }

  .navbar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: var(--nav-height);
    gap: var(--space-4);
  }

  /* ─── Logo ─── */
  .navbar__logo {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-shrink: 0;
  }

  .navbar__logo-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: var(--radius-xl);
    background: linear-gradient(135deg, var(--color-brand-600), var(--color-brand-800));
    color: white;
    box-shadow: 0 4px 12px rgb(2 132 199 / 0.25);
    flex-shrink: 0;
  }

  .navbar__logo-text {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }

  .navbar__logo-brand {
    font-size: var(--text-xl);
    font-weight: 900;
    color: var(--color-slate-900);
    letter-spacing: -0.025em;
  }

  .navbar__logo-sub {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-brand-600);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  /* ─── Desktop nav ─── */
  .navbar__nav {
    display: none;
  }

  @media (min-width: 768px) {
    .navbar__nav {
      display: flex;
      flex: 1;
      justify-content: center;
    }
  }

  /* ─── Actions ─── */
  .navbar__actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-shrink: 0;
  }

  .navbar__lang {
    display: none;
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--color-slate-600);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
    border: 1.5px solid var(--color-slate-200);
    transition: all var(--transition-fast);
    letter-spacing: 0.05em;
  }

  .navbar__lang:hover {
    color: var(--color-brand-600);
    border-color: var(--color-brand-600);
  }

  @media (min-width: 768px) {
    .navbar__lang {
      display: inline-flex;
      align-items: center;
    }
  }

  .navbar__cta {
    display: none;
    align-items: center;
    gap: var(--space-2);
    background-color: var(--color-brand-600);
    color: white;
    padding: var(--space-2) var(--space-5);
    border-radius: var(--radius-xl);
    font-size: var(--text-sm);
    font-weight: 600;
    transition: background-color var(--transition-fast), box-shadow var(--transition-fast);
    box-shadow: 0 4px 12px rgb(2 132 199 / 0.15);
  }

  .navbar__cta:hover {
    background-color: var(--color-brand-700);
    box-shadow: 0 4px 16px rgb(2 132 199 / 0.25);
  }

  @media (min-width: 768px) {
    .navbar__cta {
      display: inline-flex;
    }
  }

  /* ─── Burger ─── */
  .navbar__burger {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-2);
    color: var(--color-slate-600);
    border-radius: var(--radius-md);
    transition: color var(--transition-fast), background-color var(--transition-fast);
  }

  .navbar__burger:hover {
    color: var(--color-slate-900);
    background-color: var(--color-slate-100);
  }

  @media (min-width: 768px) {
    .navbar__burger {
      display: none;
    }
  }
</style>

<script>
  function initBurger() {
    const btn = document.getElementById("burger-btn");
    const menu = document.getElementById("mobile-menu");
    const iconMenu = document.getElementById("icon-menu");
    const iconClose = document.getElementById("icon-close");

    if (!btn || !menu) return;

    btn.addEventListener("click", () => {
      const isOpen = menu.classList.toggle("is-open");
      btn.setAttribute("aria-expanded", String(isOpen));

      if (iconMenu && iconClose) {
        iconMenu.style.display = isOpen ? "none" : "block";
        iconClose.style.display = isOpen ? "block" : "none";
      }

      // Prevent body scroll when menu is open
      document.body.style.overflow = isOpen ? "hidden" : "";
    });

    // Close on anchor click
    menu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        menu.classList.remove("is-open");
        btn.setAttribute("aria-expanded", "false");
        if (iconMenu && iconClose) {
          iconMenu.style.display = "block";
          iconClose.style.display = "none";
        }
        document.body.style.overflow = "";
      });
    });
  }

  // Init on first load and after view transitions
  initBurger();
  document.addEventListener("astro:page-load", initBurger);
</script>