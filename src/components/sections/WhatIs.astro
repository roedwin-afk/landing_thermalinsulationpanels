---
import { Zap, Snowflake, ShieldCheck, Package } from "lucide-astro";
import type { TranslationKeys } from "../../i18n/en";
import type { Lang } from "../../i18n/utils";

interface Props {
  t: TranslationKeys;
  lang: Lang;
}

const { t } = Astro.props;

const types = [
  {
    key:   "pir",
    title: t.whatIs.types.pir.title,
    desc:  t.whatIs.types.pir.desc,
    color: "orange",
    icon:  Zap,
  },
  {
    key:   "pur",
    title: t.whatIs.types.pur.title,
    desc:  t.whatIs.types.pur.desc,
    color: "blue",
    icon:  Snowflake,
  },
  {
    key:     "mineral",
    title: t.whatIs.types.mineral.title,
    desc:  t.whatIs.types.mineral.desc,
    color: "rose",
    icon:  ShieldCheck,
  },
  {
    key:   "eps",
    title: t.whatIs.types.eps.title,
    desc:  t.whatIs.types.eps.desc,
    color: "indigo",
    icon:  Package,
  },
];
---

<section id="what-is" class="whatis section-py" aria-labelledby="whatis-title">
  <div class="container">

    <!-- Header -->
    <div class="whatis__header reveal">
      <span class="eyebrow">{t.whatIs.eyebrow}</span>
      <h2 id="whatis-title" class="whatis__title">{t.whatIs.title}</h2>
      <p class="whatis__description">{t.whatIs.description}</p>
    </div>

    <!-- Types grid -->
    <div class="whatis__grid" role="list">
      {types.map((type, i) => (
        <article
          class={`type-card type-card--${type.color} reveal`}
          style={`--reveal-delay: ${i * 100}ms`}
          role="listitem"
        >
          <div class={`type-card__icon type-card__icon--${type.color}`} aria-hidden="true">
            <type.icon size={24} />
          </div>
          <h3 class="type-card__title">{type.title}</h3>
          <p class="type-card__desc">{type.desc}</p>
        </article>
      ))}
    </div>

  </div>
</section>

<style>
  .whatis {
    background-color: white;
    border-top: 1px solid var(--color-slate-100);
    border-bottom: 1px solid var(--color-slate-100);
  }

  .whatis__header {
    text-align: center;
    max-width: 48rem;
    margin-inline: auto;
    margin-bottom: var(--space-16);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .eyebrow {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-brand-600);
  }

  .whatis__title {
    font-size: var(--text-3xl);
    font-weight: 900;
    color: var(--color-slate-900);
    letter-spacing: -0.02em;
    line-height: 1.15;
  }

  @media (min-width: 640px) {
    .whatis__title { font-size: var(--text-4xl); }
  }

  .whatis__description {
    font-size: var(--text-base);
    color: var(--color-slate-600);
    line-height: 1.7;
    max-width: 60ch;
    margin-inline: auto;
  }

  @media (min-width: 640px) {
    .whatis__description { font-size: var(--text-lg); }
  }

  .whatis__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 640px) {
    .whatis__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .whatis__grid { grid-template-columns: repeat(4, 1fr); }
  }

  .type-card {
    padding: var(--space-6);
    background-color: var(--color-slate-50);
    border: 1px solid var(--color-slate-100);
    border-radius: var(--radius-3xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    transition: box-shadow var(--transition-normal), transform var(--transition-normal);
  }

  .type-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
  }

  .type-card__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border-radius: var(--radius-2xl);
    flex-shrink: 0;
  }

  .type-card__icon--orange { background-color: #fff7ed; color: #ea580c; }
  .type-card__icon--blue   { background-color: var(--color-brand-100); color: var(--color-brand-600); }
  .type-card__icon--rose   { background-color: #fff1f2; color: #e11d48; }
  .type-card__icon--indigo { background-color: #eef2ff; color: #4f46e5; }

  .type-card__title {
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-slate-900);
    line-height: 1.3;
  }

  .type-card__desc {
    font-size: var(--text-sm);
    color: var(--color-slate-600);
    line-height: 1.6;
  }

  .reveal { transition-delay: var(--reveal-delay, 0ms); }
</style>