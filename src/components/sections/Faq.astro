---
import type { TranslationKeys } from "../../i18n/en";

interface Props {
  t: TranslationKeys;
}

const { t } = Astro.props;
const f = t.faq;
const items = Object.values(f.items);
---

<section id="faq" class="faq reveal">
  <div class="container">

    <div class="faq__header">
      <span class="faq__eyebrow">{f.eyebrow}</span>
      <h2 class="faq__title">{f.title}</h2>
      <p class="faq__desc">{f.description}</p>
    </div>

    <ul class="faq__list">
      {items.map((item, i) => (
        <li class="faq__item">
          <button
            class="faq__question"
            aria-expanded="false"
            aria-controls={`faq-answer-${i}`}
            id={`faq-btn-${i}`}
            type="button"
          >
            <span>{item.question}</span>
            <span class="faq__icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20"
                viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="6 9 12 15 18 9"/>
              </svg>
            </span>
          </button>
          <div
            class="faq__answer"
            id={`faq-answer-${i}`}
            role="region"
            aria-labelledby={`faq-btn-${i}`}
          >
            <p>{item.answer}</p>
          </div>
        </li>
      ))}
    </ul>

  </div>
</section>

<script>
  function initFaq() {
    document.querySelectorAll<HTMLButtonElement>(".faq__question").forEach(btn => {
      btn.addEventListener("click", () => {
        const expanded = btn.getAttribute("aria-expanded") === "true";
        const answerId = btn.getAttribute("aria-controls");
        const answer = answerId ? document.getElementById(answerId) : null;

        // Cerrar todos los demás
        document.querySelectorAll<HTMLButtonElement>(".faq__question").forEach(other => {
          if (other !== btn) {
            other.setAttribute("aria-expanded", "false");
            other.closest(".faq__item")?.classList.remove("is-open");
            const otherId = other.getAttribute("aria-controls");
            const otherAnswer = otherId ? document.getElementById(otherId) : null;
            if (otherAnswer) otherAnswer.style.maxHeight = "0px";
          }
        });

        // Toggle el actual
        const isNowOpen = !expanded;
        btn.setAttribute("aria-expanded", String(isNowOpen));
        btn.closest(".faq__item")?.classList.toggle("is-open", isNowOpen);

        if (answer) {
          answer.style.maxHeight = isNowOpen ? `${answer.scrollHeight}px` : "0px";
        }
      });
    });
  }

  document.addEventListener("astro:page-load", initFaq);
</script>

<style>
  .faq {
    background: var(--color-slate-50);
    padding-block: var(--space-24);
    border-top: 1px solid var(--color-slate-100);
  }

  /* ── Header ── */
  .faq__header {
    text-align: center;
    /* max-width: 42rem; */
    margin-inline: auto;
    margin-bottom: var(--space-12);
  }

  .faq__eyebrow {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-brand-600);
    margin-bottom: var(--space-3);
  }

  .faq__title {
    font-size: var(--text-3xl);
    font-weight: 800;
    color: var(--color-slate-900);
    line-height: 1.2;
    margin-bottom: var(--space-4);
  }

  @media (min-width: 640px) {
    .faq__title { font-size: var(--text-4xl); }
  }

  .faq__desc {
    font-size: var(--text-base);
    color: var(--color-slate-600);
    line-height: 1.7;
  }

  /* ── List ── */
  .faq__list {
    /* max-width: 48rem; */
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  /* ── Item ── */
  .faq__item {
    background: white;
    border: 1px solid var(--color-slate-200);
    border-radius: var(--radius-2xl);
    overflow: hidden;
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
  }

  .faq__item:hover {
    border-color: var(--color-brand-200);
  }

  .faq__item.is-open {
    border-color: var(--color-brand-200);
    box-shadow: 0 4px 20px -4px color-mix(in srgb, var(--color-brand-600) 10%, transparent);
  }

  /* ── Question button ── */
  .faq__question {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-5) var(--space-6);
    background: none;
    border: none;
    font-family: inherit;
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-slate-900);
    text-align: left;
    cursor: pointer;
    transition: color var(--transition-fast);
  }

  @media (min-width: 640px) {
    .faq__question { font-size: var(--text-base); }
  }

  .faq__item.is-open .faq__question {
    color: var(--color-brand-700);
  }

  /* ── Chevron icon ── */
  .faq__icon {
    flex-shrink: 0;
    color: var(--color-slate-400);
    transition: transform var(--transition-normal), color var(--transition-fast);
    display: flex;
    align-items: center;
  }

  .faq__item.is-open .faq__icon {
    transform: rotate(180deg);
    color: var(--color-brand-600);
  }

  /* ── Answer panel ── */
  .faq__answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .faq__answer p {
    padding: 0 var(--space-6) var(--space-5);
    font-size: var(--text-sm);
    color: var(--color-slate-600);
    line-height: 1.75;
    border-top: 1px solid var(--color-slate-100);
    padding-top: var(--space-4);
  }
</style>