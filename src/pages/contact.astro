---
import Layout from "../layouts/Layout.astro";
import { getLang, useTranslations, getAlternatePath } from "../i18n/utils";
import { Phone, Mail, MapPin } from "lucide-astro";

const base = import.meta.env.BASE_URL;
const lang = getLang(Astro.url, base);
const t = useTranslations(lang);
const alternatePath = getAlternatePath(Astro.url, base);
---

<Layout
  t={t}
  lang={lang}
  canonicalURL={Astro.url.href}
  alternatePath={alternatePath}
>
  <section class="contact">
    <div class="contact__radial" aria-hidden="true"></div>

    <div class="container">
      <div class="contact__grid">

        <!-- Columna izquierda -->
        <div class="contact__info reveal">
          <span class="contact__eyebrow">{t.contact.label}</span>
          <h1 class="contact__title">{t.contact.title}</h1>
          <p class="contact__desc">{t.contact.description}</p>

          <div class="contact__details">
            <a href={`tel:${t.contact.phone.replace(/\s/g, "")}`} class="contact-detail">
              <span class="contact-detail__icon">
                <Phone size={18} aria-hidden="true" />
              </span>
              <div>
                <span class="contact-detail__label">{t.contact.phone_label}</span>
                <span class="contact-detail__value">{t.contact.phone}</span>
              </div>
            </a>

            <a href={`mailto:${t.contact.email}`} class="contact-detail">
              <span class="contact-detail__icon">
                <Mail size={18} aria-hidden="true" />
              </span>
              <div>
                <span class="contact-detail__label">{t.contact.email_label}</span>
                <span class="contact-detail__value">{t.contact.email}</span>
              </div>
            </a>

            <div class="contact-detail">
              <span class="contact-detail__icon">
                <MapPin size={18} aria-hidden="true" />
              </span>
              <div>
                <span class="contact-detail__label">{t.contact.address_label}</span>
                <span class="contact-detail__value">{t.contact.address}</span>
              </div>
            </div>
          </div>

          <!-- Mapa -->
          <div id="contact-map" class="contact__map" aria-label="Office location map"></div>
        </div>

        <!-- Columna derecha: formulario -->
        <div class="contact__form reveal" style="--reveal-delay: 150ms">
          <div class="form-card">
            <form
              action="https://forms.zohopublic.com/promaica/form/SolicituddeCotizacin/formperma/0G7mUvm1mHqTMr77oTQpng90acA6JYYKZtboiNDls70/htmlRecords/submit"
              name="form"
              id="contact-zoho-form"
              method="POST"
              accept-charset="UTF-8"
              enctype="multipart/form-data"
            >
              <input type="hidden" name="zf_referrer_name" value="" />
              <input type="hidden" name="zf_redirect_url" value="" />
              <input type="hidden" name="zc_gad" value="" />

              <div class="form-row form-row--2col">
                <div class="form-group">
                  <label class="form-label" for="name-first">
                    {t.contact.form.firstName} {t.contact.form.required}
                  </label>
                  <input
                    id="name-first"
                    class="form-input"
                    type="text"
                    maxlength="255"
                    name="Name_First"
                    required
                    placeholder="John"
                  />
                </div>
                <div class="form-group">
                  <label class="form-label" for="name-last">
                    {t.contact.form.lastName} {t.contact.form.required}
                  </label>
                  <input
                    id="name-last"
                    class="form-input"
                    type="text"
                    maxlength="255"
                    name="Name_Last"
                    required
                    placeholder="Smith"
                  />
                </div>
              </div>

              <div class="form-group">
                <label class="form-label" for="contact-email">
                  {t.contact.form.email} {t.contact.form.required}
                </label>
                <input
                  id="contact-email"
                  class="form-input"
                  type="email"
                  maxlength="255"
                  name="Email"
                  required
                  placeholder="you@company.com"
                />
              </div>

              <div class="form-group">
                <label class="form-label" for="contact-phone">
                  {t.contact.form.phone}
                </label>
                <input
                  id="contact-phone"
                  class="form-input"
                  type="tel"
                  name="PhoneNumber_countrycode"
                  maxlength="20"
                  placeholder="+1 000 000 0000"
                />
              </div>

              <div class="form-group">
                <label class="form-label" for="contact-message">
                  {t.contact.form.message} {t.contact.form.required}
                </label>
                <textarea
                  id="contact-message"
                  class="form-input form-textarea"
                  name="MultiLine"
                  maxlength="65535"
                  required
                  placeholder={t.contact.form.messagePlaceholder}
                ></textarea>
              </div>

              <button type="submit" class="form-submit">
                {t.contact.form.submit}
              </button>
            </form>
          </div>
        </div>

      </div>
    </div>
  </section>
</Layout>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script is:inline>
  var mapInstance = null;

  function initMap() {
    var el = document.getElementById("contact-map");
    if (!el) return;
    if (typeof L === "undefined") {
      setTimeout(initMap, 100);
      return;
    }
    if (mapInstance) {
      mapInstance.remove();
      mapInstance = null;
      el.innerHTML = "";
    }

    mapInstance = L.map("contact-map", {
      center: [19.4326, -99.1948],
      zoom: 15,
      zoomControl: true,
      scrollWheelZoom: false,
    });

    L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
      attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
      maxZoom: 19,
    }).addTo(mapInstance);

    var icon = L.divIcon({
      className: "",
      html: '<div style="position:relative;width:20px;height:20px;display:flex;align-items:center;justify-content:center;"><div style="position:absolute;width:32px;height:32px;background:rgba(2,132,199,0.25);border-radius:50%;top:50%;left:50%;transform:translate(-50%,-50%);animation:mppulse 2s infinite;"></div><div style="width:14px;height:14px;background:#0284c7;border:2px solid #fff;border-radius:50%;box-shadow:0 0 10px rgba(2,132,199,0.8);position:relative;z-index:1;"></div></div><style>@keyframes mppulse{0%{transform:translate(-50%,-50%) scale(1);opacity:0.6}100%{transform:translate(-50%,-50%) scale(2.2);opacity:0}}</style>',
      iconSize: [20, 20],
      iconAnchor: [10, 10],
    });

    L.marker([19.4326, -99.1948], { icon }).addTo(mapInstance);
  }

  initMap();
  document.addEventListener("astro:page-load", initMap);
</script>

<style>
  .contact {
    position: relative;
    min-height: calc(100svh - var(--nav-height));
    padding-top: var(--space-20);
    padding-bottom: var(--space-20);
    background: linear-gradient(
      to bottom,
      var(--color-slate-900),
      var(--color-slate-800)
    );
    color: white;
    overflow-x: hidden;
  }

  .contact__radial {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      circle at top right,
      color-mix(in srgb, var(--color-brand-600) 8%, transparent),
      transparent 55%
    );
    pointer-events: none;
  }

  /* ── Grid ── */
  .contact__grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
    align-items: start;
  }

  @media (min-width: 1024px) {
    .contact__grid {
      grid-template-columns: 1fr 1fr;
      align-items: stretch;
    }
  }

  /* ── Left column ── */
  .contact__info {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .contact__eyebrow {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-brand-400, #38bdf8);
    background-color: color-mix(in srgb, var(--color-brand-600) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-brand-600) 25%, transparent);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    width: fit-content;
  }

  .contact__title {
    font-size: var(--text-3xl);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: white;
  }

  @media (min-width: 640px) {
    .contact__title { font-size: var(--text-4xl); }
  }

  .contact__desc {
    font-size: var(--text-base);
    color: var(--color-slate-300);
    line-height: 1.7;
  }

  /* ── Contact details ── */
  .contact__details {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .contact-detail {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    transition: opacity var(--transition-fast);
  }

  a.contact-detail:hover { opacity: 0.75; }

  .contact-detail__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    flex-shrink: 0;
    background-color: color-mix(in srgb, var(--color-brand-600) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-brand-600) 25%, transparent);
    border-radius: var(--radius-lg);
    color: var(--color-brand-400, #38bdf8);
  }

  .contact-detail__label {
    display: block;
    font-size: 0.65rem;
    font-weight: 600;
    color: var(--color-slate-400);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-1);
  }

  .contact-detail__value {
    display: block;
    font-size: var(--text-sm);
    font-weight: 600;
    color: white;
    line-height: 1.5;
  }

  /* ── Map ── */
  .contact__map {
    min-height: 240px;
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--color-slate-600) 50%, transparent);
    box-shadow: var(--shadow-lg);
  }

  /* ── Right column ── */
  .contact__form {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .form-card {
    background-color: var(--color-slate-800);
    border: 1px solid color-mix(in srgb, var(--color-slate-600) 40%, transparent);
    border-radius: var(--radius-2xl);
    padding: var(--space-8);
    flex: 1;
  }

  .form-row {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  @media (min-width: 480px) {
    .form-row--2col { flex-direction: row; }
    .form-row--2col .form-group { flex: 1; }
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .form-label {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-slate-400);
  }

  .form-input {
    width: 100%;
    background-color: var(--color-slate-900, #0f172a);
    border: 1px solid var(--color-slate-700);
    border-radius: var(--radius-lg);
    padding: var(--space-3) var(--space-4);
    font-size: var(--text-sm);
    font-family: inherit;
    color: white;
    outline: none;
    transition:
      border-color var(--transition-fast),
      box-shadow var(--transition-fast);
  }

  .form-input::placeholder { color: var(--color-slate-600); }

  .form-input:focus {
    border-color: var(--color-brand-600);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-brand-600) 15%, transparent);
  }

  .form-textarea {
    min-height: 140px;
    resize: vertical;
    line-height: 1.6;
  }

  .form-submit {
    width: 100%;
    background: var(--color-brand-600);
    color: white;
    font-weight: 700;
    font-size: var(--text-sm);
    font-family: inherit;
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-lg);
    cursor: pointer;
    transition: background var(--transition-fast), box-shadow var(--transition-fast);
    box-shadow: 0 8px 24px color-mix(in srgb, var(--color-brand-600) 25%, transparent);
    margin-top: var(--space-2);
  }

  .form-submit:hover {
    background: var(--color-brand-700);
  }
</style>