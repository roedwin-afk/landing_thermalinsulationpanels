---
import Layout from "../../layouts/Layout.astro";
import Hero from "../../components/sections/Hero.astro";
import WhatIs from "../../components/sections/WhatIs.astro";
import Benefits from "../../components/sections/Benefits.astro";
import Calculator from "../../components/sections/Calculator.astro";
import Faq from "../../components/sections/Faq.astro";
import { getLang, useTranslations, getAlternatePath } from "../../i18n/utils";

const base = import.meta.env.BASE_URL;
const lang = getLang(Astro.url, base);
const t = useTranslations(lang);
const alternatePath = getAlternatePath(Astro.url, base);

console.log({
  url: Astro.url.href,
  base,
  alternatePath,
});
---

<Layout
  t={t}
  lang={lang}
  canonicalURL={Astro.url.href}
  alternatePath={alternatePath}
>
  <Hero t={t} lang={lang} />
  <WhatIs t={t} lang={lang} />
  <Benefits t={t} lang={lang} />
  <Calculator t={t}  />
  <Faq t={t} />
</Layout>
