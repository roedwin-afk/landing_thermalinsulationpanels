---
import Layout from "../layouts/Layout.astro";
import { getLang, useTranslations, getAlternatePath } from "../i18n/utils";
import { CheckCircle, Zap, ShieldCheck, Volume2, Package } from "lucide-astro";

const base = import.meta.env.BASE_URL;
const lang = getLang(Astro.url, base);
const t = useTranslations(lang);
const alternatePath = getAlternatePath(Astro.url, base);

const pt = t.panelTypes;

const typeIcons = {
  pir:     Zap,
  pur:     Package,
  mineral: ShieldCheck,
  eps:     Volume2,
};

const typeKeys = ["pir", "pur", "mineral", "eps"] as const;
const rowKeys  = ["thermal", "fire", "acoustic", "moisture", "weight", "cost", "bestFor"] as const;
---

<Layout
  t={t}
  lang={lang}
  canonicalURL={Astro.url.href}
  alternatePath={alternatePath}
>

  <!-- ── Hero ── -->
  <section class="pt-hero">
    <div class="pt-hero__blob" aria-hidden="true"></div>
    <div class="container">
      <div class="pt-hero__inner reveal">
        <span class="pt-eyebrow">{pt.hero.eyebrow}</span>
        <h1 class="pt-hero__title">{pt.hero.title}</h1>
        <p class="pt-hero__desc">{pt.hero.description}</p>
      </div>
    </div>
  </section>

  <!-- ── Comparison Table ── -->
  <section class="pt-table-section">
    <div class="container">
      <div class="pt-section-header reveal">
        <h2 class="pt-section-title">{pt.comparison.title}</h2>
        <p class="pt-section-desc">{pt.comparison.description}</p>
      </div>

      <div class="pt-table-wrap reveal">
        <table class="pt-table">
          <thead>
            <tr>
              <th class="pt-table__th pt-table__th--feature">
                {pt.comparison.headers.feature}
              </th>
              {typeKeys.map(key => (
                <th class="pt-table__th">{pt.comparison.headers[key]}</th>
              ))}
            </tr>
          </thead>
          <tbody>
            {rowKeys.map((row, i) => (
              <tr class={i % 2 === 0 ? "pt-table__row--even" : ""}>
                <td class="pt-table__td pt-table__td--label">
                  {pt.comparison.rows[row].label}
                </td>
                {typeKeys.map(key => (
                  <td class="pt-table__td">
                    <span class={`pt-table__badge pt-table__badge--${key}`}>
                      {pt.comparison.rows[row][key]}
                    </span>
                  </td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ── Type Cards ── -->
  <section class="pt-types-section">
    <div class="container">
      <div class="pt-types-grid">
        {typeKeys.map((key, i) => {
          const type = pt.types[key];
          const Icon = typeIcons[key];
          return (
            <article
              class="pt-card reveal"
              style={`--reveal-delay: ${i * 80}ms`}
            >
              <div class="pt-card__header">
                <div class={`pt-card__icon pt-card__icon--${key}`}>
                  <Icon size={22} aria-hidden="true" />
                </div>
                <span class={`pt-card__tag pt-card__tag--${key}`}>
                  {type.tag}
                </span>
              </div>

              <h3 class="pt-card__title">{type.title}</h3>
              <p class="pt-card__desc">{type.description}</p>

              <ul class="pt-card__strengths">
                {type.strengths.map(s => (
                  <li class="pt-card__strength">
                    <CheckCircle size={14} aria-hidden="true" />
                    {s}
                  </li>
                ))}
              </ul>

              <div class="pt-card__ideal">
                <span class="pt-card__ideal-label">Ideal for</span>
                <span class="pt-card__ideal-value">{type.idealFor}</span>
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ── CTA ── -->
  <section class="pt-cta-section">
    <div class="container">
      <div class="pt-cta reveal">
        <h2 class="pt-cta__title">{pt.cta.title}</h2>
        <p class="pt-cta__desc">{pt.cta.description}</p>
        <div class="pt-cta__actions">
          <a href={`${base}#calculator`} class="pt-cta__btn pt-cta__btn--primary">
            {pt.cta.primary}
          </a>
          <a href={`${base}contact`} class="pt-cta__btn pt-cta__btn--secondary">
            {pt.cta.secondary}
          </a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ── Hero ── */
  .pt-hero {
    position: relative;
    overflow: hidden;
    background: linear-gradient(to bottom, var(--color-brand-50), white);
    padding-block: var(--space-20) var(--space-16);
    border-bottom: 1px solid var(--color-slate-100);
  }

  .pt-hero__blob {
    position: absolute;
    top: -8rem;
    right: -8rem;
    width: 28rem;
    height: 28rem;
    background: color-mix(in srgb, var(--color-brand-600) 8%, transparent);
    border-radius: 50%;
    filter: blur(72px);
    pointer-events: none;
  }

  .pt-hero__inner {
    position: relative;
    z-index: 1;
    max-width: 48rem;
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .pt-eyebrow {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-brand-600);
  }

  .pt-hero__title {
    font-size: var(--text-4xl);
    font-weight: 900;
    color: var(--color-slate-900);
    line-height: 1.15;
    letter-spacing: -0.02em;
  }

  @media (min-width: 640px) {
    .pt-hero__title { font-size: var(--text-5xl); }
  }

  .pt-hero__desc {
    font-size: var(--text-lg);
    color: var(--color-slate-600);
    line-height: 1.7;
  }

  /* ── Shared section header ── */
  .pt-section-header {
    text-align: center;
    max-width: 40rem;
    margin-inline: auto;
    margin-bottom: var(--space-10);
  }

  .pt-section-title {
    font-size: var(--text-3xl);
    font-weight: 800;
    color: var(--color-slate-900);
    margin-bottom: var(--space-3);
  }

  .pt-section-desc {
    font-size: var(--text-base);
    color: var(--color-slate-600);
    line-height: 1.6;
  }

  /* ── Comparison table ── */
  .pt-table-section {
    padding-block: var(--space-20);
    background: var(--color-slate-50);
    border-bottom: 1px solid var(--color-slate-100);
  }

  .pt-table-wrap {
    overflow-x: auto;
    border-radius: var(--radius-2xl);
    border: 1px solid var(--color-slate-200);
    box-shadow: var(--shadow-sm);
  }

  .pt-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
    background: white;
    min-width: 560px;
  }

  .pt-table__th {
    padding: var(--space-4) var(--space-5);
    text-align: center;
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-slate-500);
    background: var(--color-slate-50);
    border-bottom: 1px solid var(--color-slate-200);
  }

  .pt-table__th--feature {
    text-align: left;
    color: var(--color-slate-700);
  }

  .pt-table__row--even td {
    background: var(--color-slate-50);
  }

  .pt-table__td {
    padding: var(--space-4) var(--space-5);
    text-align: center;
    color: var(--color-slate-600);
    border-bottom: 1px solid var(--color-slate-100);
    vertical-align: middle;
  }

  .pt-table__td--label {
    text-align: left;
    font-weight: 600;
    color: var(--color-slate-800);
    white-space: nowrap;
  }

  /* Column accent badges */
  .pt-table__badge {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 600;
    padding: 0.2rem var(--space-2);
    border-radius: var(--radius-sm);
  }

  .pt-table__badge--pir     { background: var(--color-brand-100);  color: var(--color-brand-800); }
  .pt-table__badge--pur     { background: #dbeafe; color: #1e40af; }
  .pt-table__badge--mineral { background: #fce7f3; color: #9d174d; }
  .pt-table__badge--eps     { background: #ede9fe; color: #5b21b6; }

  /* ── Type cards ── */
  .pt-types-section {
    padding-block: var(--space-20);
    background: white;
  }

  .pt-types-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }

  @media (min-width: 768px) {
    .pt-types-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .pt-card {
    background: var(--color-slate-50);
    border: 1px solid var(--color-slate-200);
    border-radius: var(--radius-3xl);
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    transition: box-shadow var(--transition-normal), transform var(--transition-normal);
  }

  .pt-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
  }

  .pt-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .pt-card__icon {
    width: 2.75rem;
    height: 2.75rem;
    border-radius: var(--radius-xl);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .pt-card__icon--pir     { background: var(--color-brand-100);  color: var(--color-brand-700); }
  .pt-card__icon--pur     { background: #dbeafe; color: #1d4ed8; }
  .pt-card__icon--mineral { background: #fce7f3; color: #be185d; }
  .pt-card__icon--eps     { background: #ede9fe; color: #6d28d9; }

  .pt-card__tag {
    font-size: var(--text-xs);
    font-weight: 700;
    padding: 0.25rem var(--space-3);
    border-radius: var(--radius-full);
  }

  .pt-card__tag--pir     { background: var(--color-brand-100);  color: var(--color-brand-800); }
  .pt-card__tag--pur     { background: #dbeafe; color: #1e40af; }
  .pt-card__tag--mineral { background: #fce7f3; color: #9d174d; }
  .pt-card__tag--eps     { background: #ede9fe; color: #5b21b6; }

  .pt-card__title {
    font-size: var(--text-xl);
    font-weight: 800;
    color: var(--color-slate-900);
    line-height: 1.2;
  }

  .pt-card__desc {
    font-size: var(--text-sm);
    color: var(--color-slate-600);
    line-height: 1.75;
  }

  .pt-card__strengths {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .pt-card__strength {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-slate-700);
    font-weight: 500;
  }

  .pt-card__strength svg {
    color: var(--color-eco-600, #16a34a);
    flex-shrink: 0;
  }

  .pt-card__ideal {
    margin-top: auto;
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-slate-200);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .pt-card__ideal-label {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-slate-400);
  }

  .pt-card__ideal-value {
    font-size: var(--text-sm);
    color: var(--color-slate-700);
    font-weight: 500;
  }

  /* ── CTA ── */
  .pt-cta-section {
    padding-block: var(--space-20);
    background: var(--color-slate-50);
    border-top: 1px solid var(--color-slate-100);
  }

  .pt-cta {
    background: linear-gradient(135deg, var(--color-brand-700), var(--color-brand-900));
    border-radius: var(--radius-3xl);
    padding: var(--space-12) var(--space-8);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-5);
    position: relative;
    overflow: hidden;
  }

  .pt-cta::before {
    content: "";
    position: absolute;
    bottom: -6rem;
    right: -6rem;
    width: 20rem;
    height: 20rem;
    background: white;
    opacity: 0.05;
    border-radius: 50%;
    pointer-events: none;
  }

  .pt-cta__title {
    font-size: var(--text-3xl);
    font-weight: 800;
    color: white;
    line-height: 1.2;
  }

  @media (min-width: 640px) {
    .pt-cta__title { font-size: var(--text-4xl); }
  }

  .pt-cta__desc {
    font-size: var(--text-base);
    color: color-mix(in srgb, white 75%, transparent);
    line-height: 1.7;
    max-width: 36rem;
  }

  .pt-cta__actions {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    width: 100%;
    max-width: 24rem;
  }

  @media (min-width: 480px) {
    .pt-cta__actions {
      flex-direction: row;
      justify-content: center;
      max-width: none;
    }
  }

  .pt-cta__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-3) var(--space-8);
    border-radius: var(--radius-xl);
    font-size: var(--text-sm);
    font-weight: 700;
    transition: all var(--transition-fast);
  }

  .pt-cta__btn--primary {
    background: white;
    color: var(--color-brand-800);
  }

  .pt-cta__btn--primary:hover {
    background: var(--color-brand-50);
  }

  .pt-cta__btn--secondary {
    background: transparent;
    color: white;
    border: 1.5px solid color-mix(in srgb, white 40%, transparent);
  }

  .pt-cta__btn--secondary:hover {
    background: color-mix(in srgb, white 10%, transparent);
    border-color: color-mix(in srgb, white 60%, transparent);
  }
</style>