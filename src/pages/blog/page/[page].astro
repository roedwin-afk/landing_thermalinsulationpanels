---
import { BlogList } from "astro-blog-kit/components";
import { createWPClient, getStaticPathsForPages } from "astro-blog-kit/utils";
import { resolveHero, resolveUI } from 'astro-blog-kit';
import config from "../../../../blog.config";
import Layout from "../../../layouts/Layout.astro";
import { getLang, useTranslations, getAlternatePath } from "../../../i18n/utils";

export async function getStaticPaths() {
  const wp = createWPClient(config.wpUrl);
  const posts = await wp.getAllPosts();
  return getStaticPathsForPages(posts, { postsPerPage: config.postsPerPage ?? 5 });
}

const { posts, currentPage, totalPages } = Astro.props;

const locale = config.locale ?? 'en';
const hero = resolveHero(config.hero, locale);
const ui = resolveUI(config.ui, locale);

const bt = {
  blog: {
    tagline:     hero.tagline,
    title_line1: hero.titleLine1,
    title_line2: hero.titleLine2,
    description: hero.description,
    btncta:      ui.readMoreLabel,
    btn_prev:    ui.btnPrev,
    btn_next:    ui.btnNext,
  },
};


const base = import.meta.env.BASE_URL;
const lang = getLang(Astro.url, base);
const t = useTranslations(lang);
const alternatePath = getAlternatePath(Astro.url, base);


console.log("alternative:", alternatePath);

---

<Layout
  t={t}
  lang={lang}
  canonicalURL={Astro.url.href}
  alternatePath={alternatePath}
>
  <BlogList
    posts={posts}
    currentPage={currentPage}
    totalPages={totalPages}
    basePath={`${base}blog/page/`}
    blogBase={`${base}blog/`}
    dateLocale={config.locale ?? "en"}
    t={bt}
    locale={config.locale ?? "en"}
    layout={config.defaultLayout ?? "magazine"}
  />
</Layout>