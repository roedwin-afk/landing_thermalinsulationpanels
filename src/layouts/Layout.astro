---
import { ClientRouter } from "astro:transitions";
import Navbar from "../components/layout/Navbar.astro";
import Footer from "../components/layout/Footer.astro";
import type { TranslationKeys } from "../i18n/en";
import type { Lang } from "../i18n/utils";
import ScrollReveal from "../components/ui/ScrollReveal.astro";

interface Props {
  t: TranslationKeys;
  lang: Lang;
  canonicalURL?: string;
  alternatePath?: string;
}

const {
  t,
  lang,
  canonicalURL = Astro.url.href,
  alternatePath,
} = Astro.props;

const siteURL = import.meta.env.BASE_URL;
// const base = import.meta.env.BASE_URL;
const alternateURL = siteURL + alternatePath;
const alternateLang = lang === "en" ? "es" : "en";


---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta -->
    <title>{t.meta.title}</title>
    <meta name="description" content={t.meta.description} />
    <meta name="robots" content="index, follow" />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Hreflang -->
    <link rel="alternate" hreflang={lang} href={canonicalURL} />
    <link rel="alternate" hreflang={alternateLang} href={alternateURL} />
    <link rel="alternate" hreflang="x-default" href={siteURL + "/"} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={t.meta.title} />
    <meta property="og:description" content={t.meta.description} />
    <meta property="og:image" content={siteURL + "/og-image.jpg"} />
    <meta property="og:locale" content={lang === "en" ? "en_US" : "es_ES"} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={t.meta.title} />
    <meta name="twitter:description" content={t.meta.description} />
    <meta name="twitter:image" content={siteURL + "/og-image.jpg"} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/svg+xml" href={`${siteURL}favicon.svg`} />

    <!-- View Transitions -->
    <ClientRouter />
  </head>
  <body>
    <Navbar t={t} lang={lang} alternatePath={alternatePath} />
    <main>
      <slot />
    </main>
    <Footer t={t} lang={lang} />
    <ScrollReveal />
  </body>
</html>

<style is:global>
  /* ─── CSS Variables ─── */
  :root {
    /* Brand */
    --color-brand-50:  #f0f9ff;
    --color-brand-100: #e0f2fe;
    --color-brand-200: #bae6fd;
    --color-brand-600: #0284c7;
    --color-brand-700: #0369a1;
    --color-brand-800: #075985;
    --color-brand-900: #0c4a6e;

    /* Eco */
    --color-eco-50:  #f0fdf4;
    --color-eco-500: #22c55e;
    --color-eco-600: #16a34a;

    /* Amber */
    --color-amber-50:  #fffbeb;
    --color-amber-100: #fef3c7;
    --color-amber-500: #f59e0b;
    --color-amber-600: #d97706;

    /* Slate */
    --color-slate-50:  #f8fafc;
    --color-slate-100: #f1f5f9;
    --color-slate-200: #e2e8f0;
    --color-slate-300: #cbd5e1;
    --color-slate-400: #94a3b8;
    --color-slate-500: #64748b;
    --color-slate-600: #475569;
    --color-slate-700: #334155;
    --color-slate-800: #1e293b;
    --color-slate-900: #0f172a;
    --color-slate-950: #020617;

    /* Typography */
    --font-sans: "Inter", system-ui, -apple-system, sans-serif;

    --text-xs:   0.75rem;
    --text-sm:   0.875rem;
    --text-base: 1rem;
    --text-lg:   1.125rem;
    --text-xl:   1.25rem;
    --text-2xl:  1.5rem;
    --text-3xl:  1.875rem;
    --text-4xl:  2.25rem;
    --text-5xl:  3rem;
    --text-6xl:  3.75rem;

    /* Spacing */
    --space-1:  0.25rem;
    --space-2:  0.5rem;
    --space-3:  0.75rem;
    --space-4:  1rem;
    --space-5:  1.25rem;
    --space-6:  1.5rem;
    --space-8:  2rem;
    --space-10: 2.5rem;
    --space-12: 3rem;
    --space-16: 4rem;
    --space-20: 5rem;
    --space-24: 6rem;

    /* Radius */
    --radius-sm:  0.5rem;
    --radius-md:  0.75rem;
    --radius-lg:  1rem;
    --radius-xl:  1.25rem;
    --radius-2xl: 1.5rem;
    --radius-3xl: 1.875rem;
    --radius-full: 9999px;

    /* Shadows */
    --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
    --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
    --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
    --shadow-xl: 0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1);

    /* Transitions */
    --transition-fast:   150ms cubic-bezier(0.4, 0, 0.2, 1);
    --transition-normal: 300ms cubic-bezier(0.4, 0, 0.2, 1);

    /* Layout */
    --max-width: 80rem;
    --nav-height: 5rem;
  }

  /* ─── Reset & Base ─── */
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
    -webkit-text-size-adjust: 100%;
  }

  body {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: var(--color-slate-800);
    background-color: var(--color-slate-50);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  img, video {
    max-width: 100%;
    height: auto;
    display: block;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  button {
    cursor: pointer;
    border: none;
    background: none;
    font-family: inherit;
  }

  ul, ol {
    list-style: none;
  }

  /* ─── Utility: Container ─── */
  .container {
    width: 100%;
    max-width: var(--max-width);
    margin-inline: auto;
    padding-inline: var(--space-4);
  }

  @media (min-width: 640px) {
    .container { padding-inline: var(--space-6); }
  }

  @media (min-width: 1024px) {
    .container { padding-inline: var(--space-8); }
  }

  /* ─── Utility: Section padding ─── */
  .section-py {
    padding-block: var(--space-24);
  }

  /* ─── Utility: Visually hidden ─── */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  /* ─── Selection ─── */
  ::selection {
    background-color: var(--color-brand-100);
    color: var(--color-brand-900);
  }

  /* ─── Focus visible ─── */
  :focus-visible {
    outline: 2px solid var(--color-brand-600);
    outline-offset: 2px;
  }

  /* ─── Scroll reveal base state ─── */
  .reveal {
    opacity: 0;
    transform: translateY(1.5rem);
    transition:
      opacity 0.6s cubic-bezier(0.4, 0, 0.2, 1),
      transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>